// ============================================================
//  Mopeka Pro Check → Victron Cerbo GX MQTT Bridge
//  ESP32 – Finale Version (inkl. 3-Punkt, Trend-Filter & L/m3)
// ============================================================

#include <Arduino.h>
#include <BLEDevice.h>
#include <BLEScan.h>
#include <BLEAdvertisedDevice.h>
#include <WiFi.h>
#include <PubSubClient.h>
#include <ArduinoOTA.h>
#include <ESPmDNS.h>
#include <WebServer.h>
#include <esp_task_wdt.h>

// ============================================================
//  1. KONFIGURATION (Bitte hier eigene Daten eintragen)
// ============================================================

const char* WIFI_SSID = "DEIN_WLAN_NAME";
const char* WIFI_PASSWORD = "DEIN_PASSWORT";

const char* MQTT_BROKER = "192.168.x.x"; // IP der Venus OS / Cerbo GX Instanz
const int MQTT_PORT = 1883;
const char* MQTT_CLIENT = "ESP32_Mopeka_Bridge";
const char* PORTAL_ID = "000000000000"; // VRM Portal ID (für MQTT Topic Pfad)

// --- 3-PUNKT KALIBRIERUNG (Abstand Sensor zu Boden in mm) ---
// Ermöglicht die Anpassung an unregelmäßige Tankformen
const int MM_0 = 326;               // Sensorwert wenn Tank leer (0%)
const int MM_50 = 182;              // Sensorwert wenn Tank halb voll (50%)
const int MM_100 = 48;              // Sensorwert wenn Tank voll (100%)
const float CAPACITY_M3 = 0.012f;   // Gesamtkapazität in Kubikmetern (0.012 = 12 Liter)

const char* OTA_HOSTNAME = "mopeka-bridge";
const int BLE_SCAN_DURATION_S = 4;
const int BLE_PAUSE_DURATION_S = 11;
const uint32_t PUBLISH_INTERVAL_MS = 10000;
const uint32_t KEEPALIVE_INTERVAL_MS = 30000;

// ============================================================
//  2. DATENSTRUKTUREN
// ============================================================

// Struktur für die rohen Sensordaten vom Mopeka
struct MopekaData {
  bool valid = false;
  int heightMm = 0;
  float temperature = 0.0f;
  float battVolt = 0.0f;
  int quality = 0;
};

// Konfiguration der einzelnen Tanks
struct TankConfig {
  const char* name;
  const char* mac;          // MAC-Adresse des Sensors
  int mqttInstance;         // Victron Instanz-ID (z.B. 100, 101)
  int mqttType;             // 1=Frischwasser, 2=Abwasser, 5=Gas
};

// HIER SENSOR-MACs EINTRAGEN
const TankConfig TANKS[] = {
  { "Frischwasser", "XX:XX:XX:XX:XX:XX", 100, 1 },
  { "Grauwasser", "YY:YY:YY:YY:YY:YY", 101, 2 }
};
const int TANK_COUNT = sizeof(TANKS) / sizeof(TANKS[0]);

// Laufzeit-Status der Tanks inkl. Filter-Variablen
struct TankState {
  float levelPercent = 0.0f;
  int heightMm = 0;
  float temperature = 0.0f;
  float battVolt = 0.0f;
  int quality = 0;
  int rssi = 0;
  float history[3] = { 0, 0, 0 }; // Speicher für gleitenden Durchschnitt
  int histIdx = 0;
  float lastValidLevel = 0.0f;
  float pendingLevel = 0.0f;
  int jumpCounter = 0;            // Verhindert Ausreißer (Schwappen)
  bool initialized = false;
  uint32_t lastSeenMs = 0;
};

TankState tankStates[TANK_COUNT];
SemaphoreHandle_t tankMutex = nullptr; // Sicherung des Speicherzugriffs zwischen den Cores
WiFiClient wifiClient;
PubSubClient mqttClient(wifiClient);
WebServer webServer(80);
BLEScan* bleScan = nullptr;

bool lastWifiState = false;
bool lastMqttState = false;

// ============================================================
//  3. LOGIK: DECODER, KALIBRIERUNG, FILTER
// ============================================================

// Dekodiert das Mopeka Bluetooth Advertising Paket
MopekaData decodeMopeka(const uint8_t* d, size_t len) {
  MopekaData result;
  if (len < 10) return result;
  result.battVolt = d[3] / 32.0f;
  result.quality = (d[6] >> 6) & 0x03;
  float tempC = (float)((d[4] & 0x7F) - 40);
  result.temperature = tempC;

  // Berechnung der Höhe basierend auf Schalllaufzeit
  uint16_t raw = ((uint16_t)(d[6] & 0x3F) << 8) | d[5];
  float tempComp = 1.0f + (tempC - 24.0f) * 0.002f; // Temperaturkompensation Schallgeschwindigkeit

  // Korrigierter Faktor 0.1732 für +2mm Distanz-Anpassung
  result.heightMm = (int)(raw * 0.1732f * tempComp);

  result.valid = true;
  return result;
}

// 3-Punkt Linearisierung für die Prozentberechnung
float calcLevel3Point(int heightMm) {
  if (heightMm >= MM_0) return 0.0f;
  if (heightMm <= MM_100) return 1.0f;
  if (heightMm > MM_50) {
    return 0.5f * (float)(MM_0 - heightMm) / (float)(MM_0 - MM_50);
  } else {
    return 0.5f + 0.5f * (float)(MM_50 - heightMm) / (float)(MM_50 - MM_100);
  }
}

// Slosh-Filter (Schwappschutz): Unterdrückt kurzzeitige Pegelsprünge
float sloshFilter(int idx, float newLevel) {
  TankState& s = tankStates[idx];
  if (!s.initialized) {
    for (int i = 0; i < 3; i++) s.history[i] = newLevel;
    s.lastValidLevel = newLevel;
    s.initialized = true;
    return newLevel;
  }

  float diff = fabsf(newLevel - s.lastValidLevel);

  // Trend-Check: Wenn Änderung groß (>15%), prüfe ob sie konsistent ist
  if (diff > 0.15f && (millis() - s.lastSeenMs < 60000)) {
    if (fabsf(newLevel - s.pendingLevel) < 0.02f) {
      s.jumpCounter++;
    } else {
      s.pendingLevel = newLevel;
      s.jumpCounter = 0;
    }
    if (s.jumpCounter < 2) return s.lastValidLevel; // Ignoriere Sprung, bis er 2x bestätigt wurde
  }

  // Gleitender Durchschnitt über 3 Werte
  s.jumpCounter = 0;
  s.history[s.histIdx] = newLevel;
  s.histIdx = (s.histIdx + 1) % 3;
  float sum = 0;
  for (int i = 0; i < 3; i++) sum += s.history[i];
  s.lastValidLevel = sum / 3.0f;
  return s.lastValidLevel;
}

// ============================================================
//  4. BLE CALLBACK
// ============================================================

class MopekaCallbacks : public BLEAdvertisedDeviceCallbacks {
  void onResult(BLEAdvertisedDevice dev) override {
    String mac = dev.getAddress().toString().c_str();
    int idx = -1;
    for (int i = 0; i < TANK_COUNT; i++) {
      if (mac.equalsIgnoreCase(TANKS[i].mac)) {
        idx = i;
        break;
      }
    }
    if (idx < 0 || !dev.haveManufacturerData()) return;

    std::string mfgData = dev.getManufacturerData();
    MopekaData data = decodeMopeka((const uint8_t*)mfgData.data(), mfgData.length());

    if (data.valid) {
      float rawPct = calcLevel3Point(data.heightMm);
      float filteredPct = sloshFilter(idx, rawPct);

      // Daten sicher in den globalen Status schreiben
      if (xSemaphoreTake(tankMutex, pdMS_TO_TICKS(50)) == pdTRUE) {
        TankState& s = tankStates[idx];
        s.levelPercent = filteredPct;
        s.heightMm = data.heightMm;
        s.temperature = data.temperature;
        s.battVolt = data.battVolt;
        s.quality = data.quality;
        s.rssi = dev.getRSSI();
        s.lastSeenMs = millis();
        xSemaphoreGive(tankMutex);
      }

      // Debug-Ausgabe auf der seriellen Konsole
      float curL = filteredPct * CAPACITY_M3 * 1000.0f;
      float curM3 = filteredPct * CAPACITY_M3;
      Serial.printf("[BLE] %s | %dmm | %.1f%% | Qual:%d* | %d°C | %.2fV | %.1fL (%.4fm3) | %ddBm\n",
                    TANKS[idx].name, data.heightMm, filteredPct * 100.0f, data.quality,
                    (int)data.temperature, data.battVolt, curL, curM3, dev.getRSSI());
    }
  }
};

// ============================================================
//  5. VERBINDUNGSMANAGEMENT & TASKS
// ============================================================

// Task für das Bluetooth-Scanning (läuft auf Core 1)
void bleTask(void* p) {
  bleScan->setAdvertisedDeviceCallbacks(new MopekaCallbacks(), false);
  while (true) {
    esp_task_wdt_reset();
    bleScan->start(BLE_SCAN_DURATION_S, false);
    bleScan->clearResults();
    vTaskDelay(pdMS_TO_TICKS(BLE_PAUSE_DURATION_S * 1000));
  }
}

// Überprüft WLAN-Status
bool checkWiFi() {
  bool current = (WiFi.status() == WL_CONNECTED);
  if (current != lastWifiState) {
    if (current) Serial.printf("[WIFI] Verbunden. IP: %s\n", WiFi.localIP().toString().c_str());
    else Serial.println("[WIFI] Verbindung verloren – warte...");
    lastWifiState = current;
  }
  return current;
}

// Überprüft MQTT-Status und stellt Verbindung wieder her
bool checkMQTT() {
  bool current = mqttClient.connected();
  if (current != lastMqttState) {
    if (current) Serial.println("[MQTT] Verbunden mit Cerbo GX.");
    else if (checkWiFi()) Serial.println("[MQTT] Verbindung verloren – Reconnect...");
    lastMqttState = current;
  }
  if (!current && checkWiFi()) {
    if (mqttClient.connect(MQTT_CLIENT)) {
      char topic[80];
      snprintf(topic, 80, "R/%s/keepalive", PORTAL_ID); // Victron benötigt Keepalive zum Empfangen
      mqttClient.publish(topic, "");
    }
  }
  return mqttClient.connected();
}

// Sendet die Tankdaten im Victron-kompatiblen JSON-Format via MQTT
void publishTank(int idx) {
  if (!mqttClient.connected()) return;
  TankState s;
  if (xSemaphoreTake(tankMutex, pdMS_TO_TICKS(100)) == pdTRUE) {
    s = tankStates[idx];
    xSemaphoreGive(tankMutex);
  }
  if (!s.initialized) return;

  char base[80], topic[120], payload[64], buf[32];
  snprintf(base, 80, "W/%s/tank/%d", PORTAL_ID, TANKS[idx].mqttInstance);

  // Helper Lambda zum Versenden der MQTT-Messages
  auto send = [&](const char* sub, const char* val) {
    snprintf(topic, 120, "%s%s", base, sub);
    snprintf(payload, 64, "{\"value\":%s}", val);
    mqttClient.publish(topic, payload);
  };

  send("/Status", (s.quality == 0) ? "4" : "0"); // Status 4 = Fehler/Kein Signal
  snprintf(buf, 32, "%d", TANKS[idx].mqttType);
  send("/FluidType", buf);
  snprintf(buf, 32, "%.1f", s.levelPercent * 100.0f);
  send("/Level", buf);
  snprintf(buf, 32, "%.4f", s.levelPercent * CAPACITY_M3);
  send("/Remaining", buf);
  snprintf(buf, 32, "%.4f", CAPACITY_M3);
  send("/Capacity", buf);
  snprintf(buf, 32, "%d", (int)s.temperature);
  send("/Temperature", buf);
  snprintf(buf, 32, "%.2f", s.battVolt);
  send("/BatteryVoltage", buf);
}

// Haupt-MQTT Task (läuft auf Core 0)
void mqttTask(void* p) {
  mqttClient.setServer(MQTT_BROKER, MQTT_PORT);
  uint32_t lastPub = 0, lastKA = 0;
  while (true) {
    esp_task_wdt_reset();
    if (checkMQTT()) {
      mqttClient.loop();
      uint32_t now = millis();
      if (now - lastPub >= PUBLISH_INTERVAL_MS) {
        for (int i = 0; i < TANK_COUNT; i++) publishTank(i);
        lastPub = now;
      }
      if (now - lastKA >= KEEPALIVE_INTERVAL_MS) {
        char topic[80];
        snprintf(topic, 80, "R/%s/keepalive", PORTAL_ID);
        mqttClient.publish(topic, "");
        lastKA = now;
      }
    }
    ArduinoOTA.handle();
    webServer.handleClient();
    vTaskDelay(pdMS_TO_TICKS(100));
  }
}

// ============================================================
//  6. WEB DASHBOARD (Einfaches HTML Interface)
// ============================================================

void handleRoot() {
  String html = "<html><head><meta charset='UTF-8'><meta http-equiv='refresh' content='10'><style>body{font-family:sans-serif;background:#1a1a2e;color:#eee;padding:20px;}.card{background:#16213e;padding:15px;border-radius:10px;margin-bottom:10px;}.ok{color:#2ecc71;}.err{color:#e74c3c;}</style></head><body>";
  html += "<h1>Mopeka Bridge</h1>";
  html += "<p>WLAN: " + String(lastWifiState ? "<span class='ok'>OK</span>" : "<span class='err'>Warten</span>");
  html += " | MQTT: " + String(lastMqttState ? "<span class='ok'>OK</span>" : "<span class='err'>Warten</span>") + "</p>";
  for (int i = 0; i < TANK_COUNT; i++) {
    TankState s = tankStates[i];
    html += "<div class='card'><h2>" + String(TANKS[i].name) + "</h2>";
    if (s.initialized) {
      float liters = s.levelPercent * CAPACITY_M3 * 1000.0f;
      html += "Level: <b>" + String(s.levelPercent * 100.0f, 1) + "%</b> (" + String(liters, 1) + " L)<br>";
      html += "Distanz: " + String(s.heightMm) + "mm | Qual: " + String(s.quality) + "*<br>";
      html += "Temp: " + String((int)s.temperature) + "°C | Batt: " + String(s.battVolt, 2) + "V</div>";
    } else {
      html += "Warte auf Daten...</div>";
    }
  }
  html += "</body></html>";
  webServer.send(200, "text/html", html);
}

// ============================================================
//  7. SETUP & LOOP
// ============================================================

void setup() {
  Serial.begin(115200);
  tankMutex = xSemaphoreCreateMutex();
  WiFi.mode(WIFI_STA);
  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);

  BLEDevice::init("");
  bleScan = BLEDevice::getScan();
  bleScan->setActiveScan(true);

  webServer.on("/", handleRoot);
  webServer.begin();
  ArduinoOTA.setHostname(OTA_HOSTNAME);
  ArduinoOTA.begin();

  // Watchdog Timer initialisieren (120 Sekunden)
  esp_task_wdt_init(120, true);
  esp_task_wdt_add(NULL);

  // Multitasking: BLE auf Core 1, MQTT/Web auf Core 0
  xTaskCreatePinnedToCore(bleTask, "BLE", 8192, NULL, 1, NULL, 1);
  xTaskCreatePinnedToCore(mqttTask, "MQTT", 8192, NULL, 1, NULL, 0);

  Serial.println("[SYSTEM] Bridge gestartet.");
}

void loop() {
  esp_task_wdt_reset();
  vTaskDelay(pdMS_TO_TICKS(1000));
}
